@{
    ViewData["Title"] = "Meus Agendamentos";
}

@model List<Nobeach.Models.Agendamento>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Meus Agendamentos</h1>
            <p class="text-muted">Acompanhe e gerencie seus próximos agendamentos.</p>
        </div>
        <div>
            <a href="/Home/Agenda" class="btn btn-success">Agendar</a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-secondary">Você não tem agendamentos.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var agendamento in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@agendamento.Esporte</h5>
                            <p class="card-text mb-1"><strong>Data:</strong> @agendamento.Data.ToString("dd/MM/yyyy")</p>
                            <p class="card-text mb-1"><strong>Hora:</strong> @agendamento.Hora.ToString(@"hh\:mm")</p>
                            <p class="card-text mb-2"><strong>Quadra:</strong> @agendamento.Quadra</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">Status: @agendamento.Status</small>
                                <form action="/Home/CancelarAgendamentos" method="post" onsubmit="return confirm('Tem certeza que deseja cancelar este agendamento?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@agendamento.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Cancelar</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
                </tbody>
