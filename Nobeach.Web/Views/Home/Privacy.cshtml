@{
    ViewData["Title"] = "Pagina principal";
}
<text align="center"><h1>Bem-vindo!</h1>
<h1>Marque seu horário!</h1>
<a align="center" href="Agenda" class="btn btn-warning">Agendar</a>
</text>


@model List<Nobeach.Models.Agendamento>
    <div class="container mt-5">
        <h2 style="text-align: center;">Meus Agendamentos</h2>
        @if (Model == null || !Model.Any())
        {
            <p>Você não tem agendamentos.</p>
        }
        else
        {
           
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Hora</th>
                        <th>Quadra</th>
                        <th>Esporte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agendamento in Model)
                    {
                        <tr>
                            <td>@agendamento.Data.ToString("dd/MM/yyyy")</td>
                            <td>@agendamento.Hora</td>
                            <td>@agendamento.Quadra</td>
                            <td>@agendamento.Esporte</td>
                            <td>
                                
                                <form action="/Home/CancelarAgendamentos" method="post">
                                @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@agendamento.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Cancelar</button>
                               </form>
                                
                            </td>
                        </tr>
                    }
                    
                </tbody>
            </table>
        }


        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
 <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
 