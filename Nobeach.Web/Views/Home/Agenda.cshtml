@{
    ViewData["Title"] = "Agendamento";
}
@* Página de agendamento: permite escolher data, horário, quadra e esporte.
   O calendário desabilita datas marcadas como folga (carregadas em ViewBag.DatasBloqueadas).
   O select de horários é preenchido via ViewBag.HorariosDisponiveis ou por AJAX. *@
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger mx-auto mt-4" role="alert" style="max-width:600px;">
        @TempData["Erro"]
    </div>
}
@{
    TempData.Remove("Erro");
}

@using System.Collections.Generic;
@using Nobeach.Enums;

<section class="agenda-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="agenda-card">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Agendar Horário</h3>
                        <p class="text-muted mb-0">Preencha os dados abaixo para confirmar seu agendamento.</p>
                    </div>
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <strong>⚠️ Informações Importantes:</strong>
                        <ul class="mb-0 mt-2">
                            <li><strong>Valor:</strong> R$ 80,00</li>
                            <li><strong>Pagamento:</strong> No local</li>
                            <p><strong>Não é possível trocar o esporte após o agendamento</strong>
                            <p><strong>55 minutos de uso</strong></p>
                        </ul>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <li><strong>Promoção Inicial:</strong> Este Sábado 04/06, o valor de agendamento será de R$ 50,00. Aproveite!</li>
                    </div>
                    <form method="post" action="/Home/ConfirmarAgendamento">
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
<div class="mb-3">
    <label for="nome" class="form-label">Nome</label>

    <input type="text"
           id="nome"
           name="nome"
           class="form-control form-control-lg"
           required />
</div>
<div class="mb-3">
    <label for="data" class="form-label">Data</label>

    <input type="text"
           id="data"
           name="data"
           class="form-control form-control-lg"
           value="@ViewBag.DataSelecionada"
           required />
</div>
<div class="mb-3">
    <label class="form-label">Horários</label>

    <div id="horariosContainer" class="row row-cols-2 row-cols-md-3 g-2">

        @{
            var horarios = ViewBag.HorariosDisponiveis as IEnumerable<string>;
        }

        @if (horarios != null)
        {
            foreach (var horario in horarios)
            {
                var horarioId = horario.Replace(":", "");

                <div class="col">
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="horas"
                               value="@horario"
                               id="hora_@horarioId">

                        <label class="form-check-label"
                               for="hora_@horarioId">
                            @horario
                        </label>
                    </div>
                </div>
            }
        }

    </div>

    <div class="form-text">
        Selecione um ou mais horários.
    </div>
</div>

                        <div class="mb-3">
                            <label for="quadra" class="form-label">Quadra</label>
                            <select id="quadra" name="quadra" class="form-control form-control-lg" required>
                                <option value="">Selecione uma quadra</option>
                                @if (ViewBag.Quadras != null)
                                {
                                    foreach (var quadra in (List<Nobeach.Models.Quadra>)ViewBag.Quadras)
                                    {
                                        <option value="@quadra.Id">Quadra @quadra.Id</option>
                                    }
                                    if (((List<Nobeach.Models.Quadra>)ViewBag.Quadras).Count == 0)
                                    {
                                        <option value="">Nenhuma quadra disponível para este horário</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label for="Esporte" class="form-label">Esporte</label>
                            <select id="Esporte" name="Esporte" class="form-control form-control-lg" required>
                                <option value="">Selecione um esporte</option>
                                @foreach (Esporte esporte in Enum.GetValues<Esporte>())
                                {
                                    <option value="@esporte">@esporte</option>
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-hero btn-lg w-100">Confirmar Agendamento</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
    <script>
        const blockedDates = @Html.Raw(Json.Serialize(ViewBag.DatasBloqueadas ?? new List<string>()));

        function atualizarHorarios(data) {
            if (!data) return;

            fetch('/Home/BuscarHorarios?DataSelecionada=' + data).then(response => {
                    if (!response.ok) throw new Error('Erro na resposta do servidor');
                    return response.json();
          })
                .then(horarios => {
                    const container = document.getElementById('horariosContainer');
                    if (container) {
                        container.innerHTML = '';
                        horarios.forEach(horario => {
                            const horarioId = horario.replace(/[:\s]/g, '');
                            const col = document.createElement('div');
                            col.className = 'col';
                            col.innerHTML = `
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="horas" value="${horario}" id="hora_${horarioId}" />
                                    <label class="form-check-label" for="hora_${horarioId}">${horario}</label>
                                </div>
                            `;
                            container.appendChild(col);
                        });
                    }
                })
                .catch(error => console.error('Erro no Fetch:', error));
        }

        document.addEventListener('DOMContentLoaded', function () {
            flatpickr("#data", {
                locale: "pt",
                minDate: "today",
                dateFormat: "Y-m-d",
                disable: blockedDates,
                onChange: function (selectedDates, dateStr) {
                    atualizarHorarios(dateStr);
                }
            });
        });
    </script>
}       
               
