@{
    ViewData["Title"] = "Agendamento";
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger mx-auto mt-4" role="alert" style="max-width:600px;">
        @TempData["Erro"]
    </div>
}
@{
    TempData.Remove("Erro");
}

@using System.Collections.Generic;
@using Nobeach.Enums;

<section class="agenda-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="agenda-card">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Agendar Horário</h3>
                        <p class="text-muted mb-0">Preencha os dados abaixo para confirmar seu agendamento.</p>
                    </div>
                    <form method="post" action="/Home/ConfirmarAgendamento">
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                        <div class="mb-3">
                            <label for="nome" class="form-label">Nome</label>
                            <input type="text" id="nome" name="nome" class="form-control form-control-lg" placeholder="Digite seu nome" required />
                        </div>

                        <div class="mb-3">
                            <label for="data" class="form-label">Data</label>
                            <input type="text" id="data" name="data" class="form-control form-control-lg" placeholder="Selecione a data" autocomplete="off" required value="@ViewBag.DataSelecionada" />
                        </div>

                        <div class="mb-3">
                            <label for="hora" class="form-label">Hora</label>
                            <select id="hora" name="hora" class="form-control form-control-lg" required>
                                <option value="">Selecione um horário</option>
                                @{
                                    var horarios = ViewBag.HorariosDisponiveis as IEnumerable<string>;
                                }
                                @if (horarios != null)
                                {
                                    foreach (var horario in horarios)
                                    {
                                        <option value="@horario">@horario</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="quadra" class="form-label">Quadra</label>
                            <select id="quadra" name="quadra" class="form-control form-control-lg" required>
                                <option value="">Selecione uma quadra</option>
                                @if (ViewBag.Quadras != null)
                                {
                                    foreach (var quadra in (List<Nobeach.Models.Quadra>)ViewBag.Quadras)
                                    {
                                        <option value="@quadra.Id">Quadra @quadra.Id</option>
                                    }
                                    if (((List<Nobeach.Models.Quadra>)ViewBag.Quadras).Count == 0)
                                    {
                                        <option value="">Nenhuma quadra disponível para este horário</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label for="Esporte" class="form-label">Esporte</label>
                            <select id="Esporte" name="Esporte" class="form-control form-control-lg" required>
                                <option value="">Selecione um esporte</option>
                                @foreach (Esporte esporte in Enum.GetValues<Esporte>())
                                {
                                    <option value="@esporte">@esporte</option>
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-hero btn-lg w-100">Confirmar Agendamento</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
    <script>
        const blockedDates = @Html.Raw(Json.Serialize(ViewBag.DatasBloqueadas ?? new List<string>()));

        function atualizarHorarios(data) {
            if (!data) return;

            fetch('/Home/BuscarHorarios?DataSelecionada=' + data)
                .then(response => {
                    if (!response.ok) throw new Error('Erro na resposta do servidor');
                    return response.json();
                })
                .then(horarios => {
                    const selectHora = document.getElementById('hora');
                    if (selectHora) {
                        selectHora.innerHTML = '<option value="">Selecione um horário</option>';
                        horarios.forEach(horario => {
                            const option = document.createElement('option');
                            option.value = horario;
                            option.textContent = horario;
                            selectHora.appendChild(option);
                        });
                    }
                })
                .catch(error => console.error('Erro no Fetch:', error));
        }

        document.addEventListener('DOMContentLoaded', function () {
            flatpickr("#data", {
                locale: "pt",
                minDate: "today",
                dateFormat: "Y-m-d",
                disable: blockedDates,
                onChange: function (selectedDates, dateStr) {
                    atualizarHorarios(dateStr);
                }
            });
        });
    </script>
}
