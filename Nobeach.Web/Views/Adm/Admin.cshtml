@{
    ViewData["Title"] = "Tabela";
}
@using Nobeach.Controllers;
@model (List<Nobeach.Models.Agendamento> Agendamentos, List<Nobeach.Models.Diaquadra> Dias)

<h1 class="text-center mt-4">Bem-vindo!<br><small class="text-muted">Aqui estão seus agendamentos</small></h1>

<div class="container mt-5">
    <h3 class="mb-3">Agendamentos </h3>
    <table class="table table-striped table-hover border">
        <thead>
            <tr>
                <th>Data</th>
                <th>Hora</th>
                <th>Cliente</th>
                <th>Quadra</th>
                <th>Esporte</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var agendamento in Model.Agendamentos)
            {
                <tr>
                    <td>@agendamento.Data.ToString("dd/MM/yyyy")</td>
                    <td>@agendamento.Hora</td>
                    <td>@agendamento.NomeCliente</td>
                    <td>@agendamento.Quadra</td>
                    <td>@agendamento.Esporte</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<hr class="container my-5" />

<div class="container mb-5">
    <h2>Gerenciar Dias Específicos</h2>
    
    <div class="card p-4 mb-4 shadow-sm">
        <form action="DataExata" method="post" class="d-flex align-items-end gap-3">
            @Html.AntiForgeryToken()
            
            <div>
                <label class="form-label">Escolha a Data:</label>
                <input type="date" name="novaData" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            
            <div>
                <label class="form-label">Neste dia eu vou:</label>
                <select name="status" class="form-select">
                    <option value="Disponível">Trabalhar (Dia Extra)</option>
                    <option value="Folga">Folgar (Não Atender)</option>
                </select>
            </div>
            
            <button type="submit" class="btn btn-success">Adicionar</button>
        </form>
    </div>

    <h4>Dias Cadastrados</h4>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Data</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dia in Model.Dias)
            {
                <tr>
                    <td>@dia.Data.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (dia.Disponivel)
                        {
                            <span class="badge bg-primary">Disponível</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Folga</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
</div>