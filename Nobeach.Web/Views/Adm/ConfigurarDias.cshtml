@{
    ViewData["Title"] = "Configurar Folgas";
}
@model List<Nobeach.Models.Diaquadra>

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="mb-4">Gerenciar Folgas</h1>
            
            <!-- Formulário para adicionar/remover folga -->
            <div class="card shadow-sm mb-5">
                <div class="card-header bg-warning">
                    <h5 class="mb-0 text-white">Adicionar ou Remover Folga</h5>
                </div>
                <div class="card-body">
                    <form method="post" action="/Adm/DataExata" class="row g-3">
                        @Html.AntiForgeryToken()
                        
                        <div class="col-md-6">
                            <label for="novaData" class="form-label">Selecione a Data:</label>
                            <input type="date" id="novaData" name="novaData" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        
                        <div class="col-md-6">
                            <label for="status" class="form-label">Status:</label>
                            <select id="status" name="status" class="form-select" required>
                                <option value="">Escolha uma opção</option>
                                <option value="Folga">Marcar como Folga</option>
                                <option value="Disponível">Marcar como Disponível</option>
                            </select>
                        </div>
                        
                        <div class="col-12">
                            <button type="submit" class="btn btn-warning btn-lg w-100">Confirmar</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Exibir folgas configuradas -->
            <div class="card shadow-sm">
                <div class="card-header bg-info">
                    <h5 class="mb-0 text-white">Folgas Configuradas</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Count > 0)
                    {
                        var folgas = Model.Where(d => !d.Disponivel).ToList();
                        
                        @if (folgas.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Data</th>
                                            <th>Dia da Semana</th>
                                            <th>Status</th>
                                            <th>Ação</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var folga in folgas.OrderBy(f => f.Data))
                                        {
                                            var diaSemana = folga.Data.ToString("dddd", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
                                            var diaSemanaCapitalizado = char.ToUpper(diaSemana[0]) + diaSemana.Substring(1);
                                            
                                            <tr>
                                                <td>@folga.Data.ToString("dd/MM/yyyy")</td>
                                                <td>@diaSemanaCapitalizado</td>
                                                <td>
                                                    <span class="badge bg-danger">Folga</span>
                                                </td>
                                                <td>
                                                    <form method="post" action="/Adm/DataExata" style="display: inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="novaData" value="@folga.Data.ToString("yyyy-MM-dd")" />
                                                        <input type="hidden" name="status" value="Disponível" />
                                                        <button type="submit" class="btn btn-sm btn-success">Remover Folga</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info" role="alert">
                                ✓ Nenhuma folga configurada. Todas as datas estão disponíveis!
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info" role="alert">
                            Nenhuma configuração de dias ainda.
                        </div>
                    }
                </div>
            </div>

            <!-- Botão para voltar -->
            <div class="mt-4">
                <a href="/Adm/Admin" class="btn btn-secondary btn-lg w-100">Voltar para Dashboard</a>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        padding: 1rem;
    }
    
    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 1.1rem;
    }
    
    .badge {
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
    }
</style>
